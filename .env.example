# =============================================================================
# Environment Configuration — Streaming Backend
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These variables configure how the server runs.
# In Step 1, we only need PORT. More will be added in later steps.
# =============================================================================

# ─── Server ──────────────────────────────────────────────────────────────────
# The port the API server listens on. Default: 8080
PORT=8080

# The environment: development, staging, or production
# (We'll use this in Step 2 to change logging behavior)
APP_ENV=development

# ─── Database (Step 3) ──────────────────────────────────────────────────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=streaming
# DB_PASSWORD=secret
# DB_NAME=streaming
# DB_SSL_MODE=disable

# ─── Redis (Step 3) ─────────────────────────────────────────────────────────
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ─── JWT Authentication (Step 4) ────────────────────────────────────────────
# JWT_SECRET=your-256-bit-secret-change-this
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL=168h

# ─── Object Storage — MinIO/S3 (Step 6) ────────────────────────────────────
# S3_ENDPOINT=localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=videos
# S3_USE_SSL=false
